# =============================================================================
# Ferry Booking App — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# VITE_* variables are exposed to the frontend (Vite).
# All other variables are used by API serverless functions.

# --- Razorpay (Required) ---
# Get your test/live keys from https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_test_YOUR_TEST_KEY_HERE
RAZORPAY_KEY_SECRET=your_test_secret_here

# --- Server Configuration (Local Dev Only) ---
# Backend API URL used by the local Express server
BACKEND_PORT=3001